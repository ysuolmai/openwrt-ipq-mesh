config controller 'main'
	option enabled '1'
	option pairing_enabled '1'
	option local_member '0'
	option network_mode 'bridge'
	option network_cidr '192.168.50.0/24'

	option ssid 'OpenWrt-Mesh'
	option ssid_2g 'OpenWrt-Mesh'
	option ssid_5g 'OpenWrt-Mesh'
	option key 'change-this-client-password'
	option country 'US'
	option encryption 'psk2+ccmp'
	option ieee80211k '1'
	option ieee80211v '1'
	option ieee80211r '1'
	option mobility_domain '4f57'
	option ft_over_ds '1'

	option mesh_id 'openwrt-easymesh-backhaul'
	option mesh_key 'change-this-mesh-password'
	option band '5g'
	option channel_5g '149'
	option channel_2g '6'
	option htmode_5g 'HE80'
	option htmode_2g 'HE20'
	option wired_preferred '1'

	option dawn_enabled '1'
	option dawn_kicking '3'
	option dawn_set_hostapd_nr '1'
