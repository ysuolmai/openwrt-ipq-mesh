#!/bin/sh

set -e

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

uci_get() {
	uci -q get "$1" 2>/dev/null || printf '%s' "$2"
}

find_bridge_section() {
	local section="$1"
	local name type

	[ -n "$BRIDGE_SECTION" ] && return 0
	config_get name "$section" name
	config_get type "$section" type
	if [ "$name" = "br-lan" ] && [ "$type" = "bridge" ]; then
		BRIDGE_SECTION="$section"
	fi
	return 0
}

add_wan_candidate() {
	local value="$1"
	local port

	for port in $value; do
		[ -n "$port" ] || continue
		case "$port" in
			br-lan|@*|none) continue ;;
		esac
		case " $WAN_PORTS " in
			*" $port "*) ;;
			*) WAN_PORTS="$WAN_PORTS $port" ;;
		esac
	done
}

collect_wan_ports() {
	WAN_PORTS=""
	add_wan_candidate "$(uci -q get network.wan.device 2>/dev/null || true)"
	add_wan_candidate "$(uci -q get network.wan.ifname 2>/dev/null || true)"
	add_wan_candidate "$(uci -q get network.wan6.device 2>/dev/null || true)"
	add_wan_candidate "$(uci -q get network.wan6.ifname 2>/dev/null || true)"
	[ -d /sys/class/net/wan ] && add_wan_candidate wan
}

bool_json() {
	[ "$1" = "1" ] && printf 1 || printf 0
}

radio_value() {
	local iface="$1"
	local key="$2"
	local radio

	radio="$(uci_get "wireless.$iface.device" "")"
	[ -n "$radio" ] || return 0
	uci_get "wireless.$radio.$key" ""
}

has_wireless_config() {
	[ -f /etc/config/wireless ] || return 1
	uci -q show wireless 2>/dev/null | grep -q '=wifi-device'
}

has_wifi_driver() {
	local phy

	for phy in /sys/class/ieee80211/*; do
		[ -e "$phy" ] && return 0
	done
	command -v iw >/dev/null 2>&1 || return 1
	iw phy >/dev/null 2>&1
}

local_wifi=0
if has_wireless_config || has_wifi_driver; then
	local_wifi=1
fi
local_member_supported=0
if [ "$local_wifi" = "1" ] && [ -x /usr/sbin/mesh-ac-apply-local ]; then
	local_member_supported=1
fi

BRIDGE_SECTION=""
config_load network
config_foreach find_bridge_section device

bridge_ports=""
if [ -n "$BRIDGE_SECTION" ]; then
	bridge_ports="$(uci_get "network.$BRIDGE_SECTION.ports" "")"
fi

collect_wan_ports
wan_bridged=0
for port in $WAN_PORTS; do
	case " $bridge_ports " in
		*" $port "*) wan_bridged=1 ;;
	esac
done

lan_proto="$(uci_get network.lan.proto unknown)"
lan_ip="$(uci_get network.lan.ipaddr "")"
wan_disabled="$(uci_get network.wan.disabled 0)"
dhcp_ignore="$(uci_get dhcp.lan.ignore 0)"
dhcp_enabled=1
[ "$dhcp_ignore" = "1" ] && dhcp_enabled=0

mode=unknown
if [ "$lan_proto" = "dhcp" ] && { [ "$wan_bridged" = "1" ] || [ "$wan_disabled" = "1" ]; }; then
	mode=bridge
elif [ "$lan_proto" = "static" ] && [ "$wan_bridged" != "1" ]; then
	mode=gateway
fi

mesh_radio="$(uci_get wireless.mesh_backhaul.device "")"
mesh_id="$(uci_get wireless.mesh_backhaul.mesh_id "")"
mesh_key="$(uci_get wireless.mesh_backhaul.key "")"
local_member_active=0
[ -n "$mesh_id" ] && local_member_active=1
client_key="$(uci_get wireless.mesh_ap_2g.key "")"
[ -n "$client_key" ] || client_key="$(uci_get wireless.mesh_ap_5g.key "")"
country="$(radio_value mesh_ap_2g country)"
[ -n "$country" ] || country="$(radio_value mesh_ap_5g country)"
backhaul_band=""
[ -n "$mesh_radio" ] && backhaul_band="$(uci_get "wireless.$mesh_radio.band" "")"

json_init

json_add_object capabilities
json_add_boolean local_wifi "$(bool_json "$local_wifi")"
json_add_boolean local_member "$(bool_json "$local_member_supported")"
json_close_object

json_add_object network
json_add_string mode "$mode"
json_add_string desired_mode "$(uci_get mesh_ac.main.network_mode bridge)"
json_add_string lan_proto "$lan_proto"
json_add_string lan_ip "$lan_ip"
json_add_string bridge_ports "$bridge_ports"
json_add_boolean wan_bridged "$(bool_json "$wan_bridged")"
json_add_boolean wan_disabled "$(bool_json "$wan_disabled")"
json_add_boolean dhcp_enabled "$(bool_json "$dhcp_enabled")"
json_close_object

json_add_object wifi
json_add_boolean local_member_active "$(bool_json "$local_member_active")"
json_add_string ssid_2g "$(uci_get wireless.mesh_ap_2g.ssid "")"
json_add_string ssid_5g "$(uci_get wireless.mesh_ap_5g.ssid "")"
json_add_string key "$client_key"
json_add_string country "$country"
json_add_string channel_2g "$(radio_value mesh_ap_2g channel)"
json_add_string channel_5g "$(radio_value mesh_ap_5g channel)"
json_add_string htmode_2g "$(radio_value mesh_ap_2g htmode)"
json_add_string htmode_5g "$(radio_value mesh_ap_5g htmode)"
json_add_string ieee80211k "$(uci_get wireless.mesh_ap_2g.ieee80211k "")"
json_add_string ieee80211v "$(uci_get wireless.mesh_ap_2g.bss_transition "")"
json_add_string ieee80211r "$(uci_get wireless.mesh_ap_2g.ieee80211r "")"
json_add_string mobility_domain "$(uci_get wireless.mesh_ap_2g.mobility_domain "")"
json_add_string mesh_id "$mesh_id"
json_add_string mesh_key "$mesh_key"
json_add_string band "$backhaul_band"
json_close_object

json_dump
