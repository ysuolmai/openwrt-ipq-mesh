#!/bin/sh

set -e

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

uci_get() {
	uci -q get "$1" 2>/dev/null || printf '%s' "$2"
}

find_bridge_section() {
	local section="$1"
	local name type

	[ -n "$BRIDGE_SECTION" ] && return 0
	config_get name "$section" name
	config_get type "$section" type
	if [ "$name" = "br-lan" ] && [ "$type" = "bridge" ]; then
		BRIDGE_SECTION="$section"
	fi
	return 0
}

add_wan_candidate() {
	local value="$1"
	local port

	for port in $value; do
		[ -n "$port" ] || continue
		case "$port" in
			br-lan|@*|none) continue ;;
		esac
		case " $WAN_PORTS " in
			*" $port "*) ;;
			*) WAN_PORTS="$WAN_PORTS $port" ;;
		esac
	done
}

collect_wan_ports() {
	WAN_PORTS=""
	add_wan_candidate "$(uci -q get network.wan.device 2>/dev/null || true)"
	add_wan_candidate "$(uci -q get network.wan.ifname 2>/dev/null || true)"
	add_wan_candidate "$(uci -q get network.wan6.device 2>/dev/null || true)"
	add_wan_candidate "$(uci -q get network.wan6.ifname 2>/dev/null || true)"
	[ -d /sys/class/net/wan ] && add_wan_candidate wan
}

bool_json() {
	[ "$1" = "1" ] && printf 1 || printf 0
}

radio_value() {
	local iface="$1"
	local key="$2"
	local radio

	radio="$(uci_get "wireless.$iface.device" "")"
	[ -n "$radio" ] || return 0
	uci_get "wireless.$radio.$key" ""
}

BRIDGE_SECTION=""
config_load network
config_foreach find_bridge_section device

bridge_ports=""
if [ -n "$BRIDGE_SECTION" ]; then
	bridge_ports="$(uci_get "network.$BRIDGE_SECTION.ports" "")"
fi

collect_wan_ports
wan_bridged=0
for port in $WAN_PORTS; do
	case " $bridge_ports " in
		*" $port "*) wan_bridged=1 ;;
	esac
done

lan_proto="$(uci_get network.lan.proto unknown)"
lan_ip="$(uci_get network.lan.ipaddr "")"
wan_disabled="$(uci_get network.wan.disabled 0)"
dhcp_ignore="$(uci_get dhcp.lan.ignore 0)"
dhcp_enabled=1
[ "$dhcp_ignore" = "1" ] && dhcp_enabled=0

mode=unknown
if [ "$lan_proto" = "dhcp" ] && { [ "$wan_bridged" = "1" ] || [ "$wan_disabled" = "1" ]; }; then
	mode=bridge
elif [ "$lan_proto" = "static" ] && [ "$wan_bridged" != "1" ]; then
	mode=gateway
fi

json_init

json_add_object network
json_add_string mode "$mode"
json_add_string desired_mode "$(uci_get mesh_ac.main.network_mode bridge)"
json_add_string lan_proto "$lan_proto"
json_add_string lan_ip "$lan_ip"
json_add_string bridge_ports "$bridge_ports"
json_add_boolean wan_bridged "$(bool_json "$wan_bridged")"
json_add_boolean wan_disabled "$(bool_json "$wan_disabled")"
json_add_boolean dhcp_enabled "$(bool_json "$dhcp_enabled")"
json_close_object

json_add_object wifi
json_add_string ssid_2g "$(uci_get wireless.mesh_ap_2g.ssid "")"
json_add_string ssid_5g "$(uci_get wireless.mesh_ap_5g.ssid "")"
json_add_string channel_2g "$(radio_value mesh_ap_2g channel)"
json_add_string channel_5g "$(radio_value mesh_ap_5g channel)"
json_add_string htmode_2g "$(radio_value mesh_ap_2g htmode)"
json_add_string htmode_5g "$(radio_value mesh_ap_5g htmode)"
json_add_string mesh_id "$(uci_get wireless.mesh_backhaul.mesh_id "")"
json_close_object

json_dump
