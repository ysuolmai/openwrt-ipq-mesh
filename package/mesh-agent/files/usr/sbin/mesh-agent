#!/bin/sh

set -eu

DEFAULT_AC_HOST="192.168.50.1"
DEFAULT_AC_PATH="/cgi-bin/mesh-ac"
AC_CACHE="/etc/mesh-agent/ac_url"
MDNS_SERVICE="_mesh-ac._tcp"

log() {
	logger -t mesh-agent "$*"
}

uci_get() {
	uci -q get "$1" 2>/dev/null || printf '%s' "$2"
}

node_id() {
	local mac
	mac="$(cat /sys/class/net/br-lan/address 2>/dev/null || cat /sys/class/net/eth0/address 2>/dev/null || echo 02:00:00:00:00:01)"
	echo "ap-$(echo "$mac" | tr -d ':' | tail -c 7)"
}

model_name() {
	ubus call system board 2>/dev/null | jsonfilter -e '@.model' 2>/dev/null || echo unknown
}

lan_mac() {
	cat /sys/class/net/br-lan/address 2>/dev/null || cat /sys/class/net/eth0/address 2>/dev/null || echo 02:00:00:00:00:01
}

post_json() {
	local url="$1"
	local body="$2"
	curl -fsS -m 10 -H 'Content-Type: application/json' -d "$body" "$url"
}

# Confirm a base URL really points at a mesh-ac service before trusting it.
probe_ac() {
	local base="$1"
	[ -n "$base" ] || return 1
	curl -fsS -m 5 "$base" 2>/dev/null | jsonfilter -e '@.service' 2>/dev/null \
		| grep -q '^mesh-ac$'
}

# Build an mesh-ac base URL from a host (and optional path/port).
ac_url_from() {
	local host="$1"
	local port="${2:-80}"
	local path="${3:-$DEFAULT_AC_PATH}"
	if [ "$port" = "80" ]; then
		printf 'http://%s%s' "$host" "$path"
	else
		printf 'http://%s:%s%s' "$host" "$port" "$path"
	fi
}

# Discover the AC via mDNS (umdns). Returns a base URL on success.
discover_mdns() {
	local raw host port path
	command -v ubus >/dev/null 2>&1 || return 1

	# Nudge umdns to query/announce, then read the cached browse table.
	# Both calls are best-effort; a passive cache hit also works.
	ubus call umdns query "{\"question\":\"$MDNS_SERVICE\"}" >/dev/null 2>&1 || true
	ubus call umdns update >/dev/null 2>&1 || true
	sleep 1
	raw="$(ubus call umdns browse 2>/dev/null)" || return 1
	[ -n "$raw" ] || return 1

	# Pick the first advertised mesh-ac instance with an IPv4 address.
	host="$(printf '%s' "$raw" \
		| jsonfilter -e "@[\"$MDNS_SERVICE\"][*].ipv4" 2>/dev/null \
		| head -n1)"
	[ -n "$host" ] || return 1

	port="$(printf '%s' "$raw" \
		| jsonfilter -e "@[\"$MDNS_SERVICE\"][*].port" 2>/dev/null \
		| head -n1)"
	[ -n "$port" ] || port=80

	path="$(printf '%s' "$raw" \
		| jsonfilter -e "@[\"$MDNS_SERVICE\"][*].txt[*]" 2>/dev/null \
		| sed -n 's/^path=//p' | head -n1)"
	[ -n "$path" ] || path="$DEFAULT_AC_PATH"

	ac_url_from "$host" "$port" "$path"
}

# Probe the default gateway, which is often the AC when it is the router.
discover_gateway() {
	local gw
	gw="$(ip route show default 2>/dev/null | awk '/default/ {print $3; exit}')"
	[ -n "$gw" ] || return 1
	ac_url_from "$gw" 80 "$DEFAULT_AC_PATH"
}

# Resolve the AC base URL according to ac_discovery mode, validating each
# candidate. Caches the last working URL so a flapping AC stays reachable.
resolve_ac() {
	local mode configured candidate cached

	mode="$(uci_get mesh_agent.main.ac_discovery auto)"
	configured="$(uci_get mesh_agent.main.ac_url '')"

	# Explicit ac_url always wins when set.
	if [ -n "$configured" ]; then
		if [ "$mode" = "static" ] || probe_ac "$configured"; then
			printf '%s' "$configured"
			return 0
		fi
		log "configured ac_url $configured not reachable, falling back to discovery"
	elif [ "$mode" = "static" ]; then
		# static mode with no ac_url: nothing else to try, use default.
		ac_url_from "$DEFAULT_AC_HOST"
		return 0
	fi

	# mDNS discovery.
	candidate="$(discover_mdns || true)"
	if [ -n "$candidate" ] && probe_ac "$candidate"; then
		log "discovered AC via mDNS: $candidate"
		printf '%s' "$candidate" > "$AC_CACHE" 2>/dev/null || true
		printf '%s' "$candidate"
		return 0
	fi

	# Default gateway probe.
	candidate="$(discover_gateway || true)"
	if [ -n "$candidate" ] && probe_ac "$candidate"; then
		log "discovered AC via gateway: $candidate"
		printf '%s' "$candidate" > "$AC_CACHE" 2>/dev/null || true
		printf '%s' "$candidate"
		return 0
	fi

	# Last known good URL.
	if [ -f "$AC_CACHE" ]; then
		cached="$(cat "$AC_CACHE" 2>/dev/null || true)"
		if [ -n "$cached" ] && probe_ac "$cached"; then
			log "using cached AC: $cached"
			printf '%s' "$cached"
			return 0
		fi
	fi

	# Hardcoded default as final fallback.
	ac_url_from "$DEFAULT_AC_HOST"
}

register() {
	local ac="$1"
	local id
	local body

	id="$(node_id)"
	body="$(printf '{"id":"%s","mac":"%s","model":"%s"}' "$id" "$(lan_mac)" "$(model_name)")"
	post_json "$ac/register" "$body" || true
}

pull_config() {
	local ac="$1"
	local id
	local body

	id="$(node_id)"
	body="$(printf '{"id":"%s"}' "$id")"
	post_json "$ac/config" "$body"
}

apply_if_approved() {
	local cfg="$1"
	local approved

	approved="$(jsonfilter -s "$cfg" -e '@.approved' 2>/dev/null || echo false)"
	[ "$approved" = "true" ] || return 1

	printf '%s' "$cfg" > /etc/mesh-agent/config.json
	/usr/sbin/mesh-agent-apply /etc/mesh-agent/config.json
}

main() {
	local ac interval cfg

	interval="$(uci_get mesh_agent.main.poll_interval 30)"
	ac=""

	while true; do
		# Resolve once, then keep using the same AC while it stays
		# reachable. Re-discover only when it drops, so the AP recovers
		# if the AC moves or only comes online later.
		if [ -z "$ac" ] || ! probe_ac "$ac"; then
			ac="$(resolve_ac)"
		fi
		register "$ac"
		cfg="$(pull_config "$ac" || true)"
		if [ -n "$cfg" ] && apply_if_approved "$cfg"; then
			log "applied AC config from $ac"
		else
			log "waiting for AC approval or config (ac=$ac)"
		fi
		sleep "$interval"
	done
}

main "$@"
