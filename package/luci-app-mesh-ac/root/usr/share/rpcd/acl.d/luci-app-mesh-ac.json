{
	"luci-app-mesh-ac": {
		"description": "Grant access to EasyMesh configuration",
		"read": {
			"uci": [ "mesh_ac" ],
			"file": {
				"/etc/mesh-ac/nodes/*.json": [ "read" ],
				"/usr/sbin/mesh-ac-list": [ "exec" ],
				"/usr/sbin/mesh-ac-status": [ "exec" ]
			}
		},
		"write": {
			"uci": [ "mesh_ac" ]
		}
	}
}
