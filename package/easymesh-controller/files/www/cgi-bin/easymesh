#!/bin/sh

set -e

. /lib/functions.sh

TMP=/tmp/easymesh

mkdir -p "$TMP" /etc/easymesh/nodes

header_json() {
	printf 'Content-Type: application/json\r\n\r\n'
}

read_body() {
	local len="${CONTENT_LENGTH:-0}"
	[ "$len" -gt 0 ] || return 0
	dd bs=1 count="$len" 2>/dev/null
}

json_get() {
	local key="$1"
	jsonfilter -s "$BODY" -e "@.$key" 2>/dev/null || true
}

uci_get() {
	uci -q get "$1" 2>/dev/null || printf '%s' "$2"
}

pairing_enabled() {
	[ "$(uci_get easymesh.main.pairing_enabled 1)" = "1" ]
}

register_node() {
	local id="$1"
	local mac="$2"
	local model="$3"
	local ip="$4"
	local now
	local file

	now="$(date +%s)"

	file="$TMP/node-$id.json"
	printf '{"id":"%s","mac":"%s","model":"%s","ip":"%s","last_seen":%s}\n' \
		"$id" "$mac" "$model" "$ip" "$now" > "$file"
	mkdir -p /etc/easymesh/nodes
	cp "$file" "/etc/easymesh/nodes/$id.json"
}

render_config() {
	local node_file="$1"
	local ssid_default

	[ -f "$node_file" ] || {
		printf '{"ok":false,"error":"unknown-node"}\n'
		return
	}
	ssid_default="$(uci_get easymesh.main.ssid OpenWrt-Mesh)"

	cat <<EOF
{
  "network": {
    "mode": "$(uci_get easymesh.main.network_mode gateway)",
    "cidr": "$(uci_get easymesh.main.network_cidr 192.168.50.0/24)"
  },
  "wifi": {
    "ssid": "$ssid_default",
    "ssid_2g": "$(uci_get easymesh.main.ssid_2g "$ssid_default")",
    "ssid_5g": "$(uci_get easymesh.main.ssid_5g "$ssid_default")",
    "key": "$(uci_get easymesh.main.key change-this-client-password)",
    "country": "$(uci_get easymesh.main.country US)",
    "encryption": "$(uci_get easymesh.main.encryption psk2+ccmp)",
    "ieee80211k": "$(uci_get easymesh.main.ieee80211k 1)",
    "ieee80211v": "$(uci_get easymesh.main.ieee80211v 1)",
    "ieee80211r": "$(uci_get easymesh.main.ieee80211r 1)",
    "mobility_domain": "$(uci_get easymesh.main.mobility_domain 4f57)",
    "ft_over_ds": "$(uci_get easymesh.main.ft_over_ds 1)"
  },
  "backhaul": {
    "mesh_id": "$(uci_get easymesh.main.mesh_id openwrt-easymesh-backhaul)",
    "mesh_key": "$(uci_get easymesh.main.mesh_key change-this-mesh-password)",
    "band": "$(uci_get easymesh.main.band 5g)",
    "channel_5g": "$(uci_get easymesh.main.channel_5g 149)",
    "channel_2g": "$(uci_get easymesh.main.channel_2g 6)",
    "htmode_5g": "$(uci_get easymesh.main.htmode_5g HE80)",
    "htmode_2g": "$(uci_get easymesh.main.htmode_2g HE20)",
    "wired_preferred": "$(uci_get easymesh.main.wired_preferred 1)"
  },
  "dawn": {
    "enabled": "$(uci_get easymesh.main.dawn_enabled 1)",
    "kicking": "$(uci_get easymesh.main.dawn_kicking 3)",
    "set_hostapd_nr": "$(uci_get easymesh.main.dawn_set_hostapd_nr 1)"
  }
}
EOF
}

PATH_INFO="${PATH_INFO:-/}"
BODY="$(read_body || true)"

case "$PATH_INFO" in
	/register)
		header_json
		id="$(json_get id)"
		mac="$(json_get mac)"
		model="$(json_get model)"
		ip="${REMOTE_ADDR:-}"
		node="/etc/easymesh/nodes/$id.json"
		if [ -z "$id" ]; then
			printf '{"ok":false,"error":"missing-id"}\n'
			exit 0
		fi
		if [ ! -f "$node" ] && ! pairing_enabled; then
			printf '{"ok":false,"error":"pairing-disabled"}\n'
			exit 0
		fi
		register_node "$id" "$mac" "$model" "$ip"
		printf '{"ok":true}\n'
		;;
	/config)
		header_json
		id="$(json_get id)"
		if [ -z "$id" ]; then
			printf '{"ok":false,"error":"missing-id"}\n'
			exit 0
		fi
		node="/etc/easymesh/nodes/$id.json"
		[ -f "$node" ] || {
			printf '{"ok":false,"error":"unknown-node"}\n'
			exit 0
		}
		render_config "$node"
		;;
	*)
		header_json
		printf '{"ok":true,"service":"easymesh"}\n'
		;;
esac
