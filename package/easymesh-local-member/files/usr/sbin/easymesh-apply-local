#!/bin/sh

set -e

. /usr/share/libubox/jshn.sh
. /usr/lib/easymesh/ath11k-nss.sh

uci_get() {
	uci -q get "$1" 2>/dev/null || printf '%s' "$2"
}

set_ath11k_nss_offload() {
	local value="$1"

	[ -f /etc/modules.d/ath11k ] || return 0
	if grep -q 'nss_offload=' /etc/modules.d/ath11k; then
		sed -i "s/nss_offload=[01]/nss_offload=$value/g" /etc/modules.d/ath11k
	else
		sed -i "s/^ath11k\\([[:space:]]\\|$\\)/ath11k nss_offload=$value\\1/" /etc/modules.d/ath11k
	fi
	echo "$value" > /sys/module/ath11k/parameters/nss_offload 2>/dev/null || true
}

has_wireless_config() {
	[ -f /etc/config/wireless ] || return 1
	uci -q show wireless 2>/dev/null | grep -q '=wifi-device'
}

has_wifi_driver() {
	local phy

	for phy in /sys/class/ieee80211/*; do
		[ -e "$phy" ] && return 0
	done
	command -v iw >/dev/null 2>&1 || return 1
	iw phy >/dev/null 2>&1
}

has_local_wifi() {
	has_wireless_config || has_wifi_driver
}

if ! has_local_wifi; then
	logger -t easymesh-controller "local mesh member support skipped: no local Wi-Fi detected"
	exit 0
fi

local_member="$(uci_get easymesh.main.local_member 0)"
network_mode="$(uci_get easymesh.main.network_mode gateway)"
network_cidr="$(uci_get easymesh.main.network_cidr 192.168.50.0/24)"
ssid_default="$(uci_get easymesh.main.ssid OpenWrt-Mesh)"

tmp="/tmp/easymesh-local-config.json"
umask 077

json_init

json_add_object network
json_add_string mode "$network_mode"
json_add_string cidr "$network_cidr"
json_close_object

if [ "$local_member" = "1" ]; then
	json_add_object wifi
	json_add_string ssid "$ssid_default"
	json_add_string ssid_2g "$(uci_get easymesh.main.ssid_2g "$ssid_default")"
	json_add_string ssid_5g "$(uci_get easymesh.main.ssid_5g "$ssid_default")"
	json_add_string key "$(uci_get easymesh.main.key change-this-client-password)"
	json_add_string country "$(uci_get easymesh.main.country US)"
	json_add_string encryption "$(uci_get easymesh.main.encryption psk2+ccmp)"
	json_add_string ieee80211k "$(uci_get easymesh.main.ieee80211k 1)"
	json_add_string ieee80211v "$(uci_get easymesh.main.ieee80211v 1)"
	json_add_string ieee80211r "$(uci_get easymesh.main.ieee80211r 1)"
	json_add_string mobility_domain "$(uci_get easymesh.main.mobility_domain 4f57)"
	json_add_string ft_over_ds "$(uci_get easymesh.main.ft_over_ds 1)"
	json_close_object

	json_add_object backhaul
	json_add_string mesh_id "$(uci_get easymesh.main.mesh_id openwrt-easymesh-backhaul)"
	json_add_string mesh_key "$(uci_get easymesh.main.mesh_key change-this-mesh-password)"
	json_add_string band "$(uci_get easymesh.main.band 5g)"
	json_add_string channel_5g "$(uci_get easymesh.main.channel_5g 149)"
	json_add_string channel_2g "$(uci_get easymesh.main.channel_2g 6)"
	json_add_string htmode_5g "$(uci_get easymesh.main.htmode_5g HE80)"
	json_add_string htmode_2g "$(uci_get easymesh.main.htmode_2g HE20)"
	json_add_string wired_preferred "$(uci_get easymesh.main.wired_preferred 1)"
	json_close_object

	json_add_object dawn
	json_add_string enabled "$(uci_get easymesh.main.dawn_enabled 1)"
	json_add_string kicking "$(uci_get easymesh.main.dawn_kicking 3)"
	json_add_string set_hostapd_nr "$(uci_get easymesh.main.dawn_set_hostapd_nr 1)"
	json_close_object
fi

json_dump > "$tmp"

if [ "$local_member" = "1" ]; then
	if ath11k_nss_set_offload 0 "AC local member enable" "/etc/easymesh/pending-local-apply"; then
		logger -t easymesh-controller "scheduled reboot before applying local mesh member config"
		exit 0
	fi
	/usr/sbin/easymesh-agent-apply --local-ac "$tmp"
	logger -t easymesh-controller "applied local mesh member config"
else
	rm -f /etc/easymesh/pending-local-apply
	ath11k_nss_set_offload 1 "AC controller mode" || true
	/usr/sbin/easymesh-agent-apply --local-ac --network-only "$tmp"
	logger -t easymesh-controller "applied AC network config"
fi
